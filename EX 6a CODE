import java.io.*;
import java.net.*;

public class ARP
{
    public static void main(String args[])
    {
        new ARPServer();
        new ARPClient();
    }
}

class ARPServer extends Thread
{
    ARPServer()
    {
        start();
    }

    public void run()
    {
        try
        {
            ServerSocket server = new ServerSocket(139);
            System.out.println("ARP Server is running...");

            Socket socket = server.accept();

            BufferedReader clientInput =
                    new BufferedReader(new InputStreamReader(socket.getInputStream()));

            DataOutputStream dout =
                    new DataOutputStream(socket.getOutputStream());

            String ip[] = {"165.165.80.80", "165.165.79.1"};
            String mac[] = {"6A:08:AA:C2", "8A:BC:E3:FA"};

            String clientIP = clientInput.readLine();

            String result = "IP not found";

            for(int i = 0; i < ip.length; i++)
            {
                if(clientIP.equals(ip[i]))
                {
                    result = mac[i];
                    break;
                }
            }

            dout.writeBytes(result + "\n");

            socket.close();
            server.close();
        }
        catch(Exception e)
        {
            System.out.println(e);
        }
    }
}

class ARPClient extends Thread
{
    ARPClient()
    {
        start();
    }

    public void run()
    {
        try
        {
            Thread.sleep(1000);

            BufferedReader in =
                    new BufferedReader(new InputStreamReader(System.in));

            Socket socket = new Socket("127.0.0.1",139);

            BufferedReader serverInput =
                    new BufferedReader(new InputStreamReader(socket.getInputStream()));

            DataOutputStream dout =
                    new DataOutputStream(socket.getOutputStream());

            System.out.print("Enter the Logical Address (IP): ");
            String ip = in.readLine();

            dout.writeBytes(ip + "\n");

            String mac = serverInput.readLine();

            System.out.println("The Physical Address is: " + mac);

            socket.close();
        }
        catch(Exception e)
        {
            System.out.println(e);
        }
    }
}
